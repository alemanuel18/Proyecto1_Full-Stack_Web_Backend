# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Docker Compose usa estas variables para crear la base de datos
# y construye DATABASE_URL automáticamente.
# Si corres sin Docker, define DATABASE_URL manualmente abajo.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia_esto_en_produccion
POSTGRES_DB=seriestracker

# Solo necesario si corres sin Docker:
# DATABASE_URL=postgres://postgres:cambia_esto@localhost:5432/seriestracker?sslmode=disable

# ── JWT ───────────────────────────────────────────────────────────────────────
# String largo y aleatorio. Puedes generar uno con: openssl rand -hex 32
JWT_SECRET=cambia_esto_por_un_string_largo_y_aleatorio

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Obtén estas credenciales en cloudinary.com > Dashboard
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=8080